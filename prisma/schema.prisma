// Schéma de base de la plateforme DumTools.
// Entités partagées entre tous les outils (User, Client, Chantier).
// Les données propres à chaque outil seront ajoutées dans des modèles dédiés
// au moment de la réécriture de l'outil concerné.
// Doc : https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBRE
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  nom          String
  passwordHash String
  role         Role         @default(MEMBRE)
  actif        Boolean      @default(true)
  /// SHA-256 (hex) du jeton d'accès MCP de l'utilisateur (jamais le jeton en
  /// clair). Null = aucun jeton actif. Voir scripts/mcp-token.mts.
  mcpTokenHash String?      @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  pointsLists  PointsList[]
  affectations AffectationProjet[]
  documents    Document[]
}

/// Référentiel client partagé, central à la plateforme. Chaque outil relie sa
/// production à un Client via `clientId` : la fiche client agrège alors tout ce
/// qui a été fait pour lui, à travers tous les outils (voir
/// src/lib/clients/providers.ts).
model Client {
  id           String              @id @default(cuid())
  nom          String              @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  chantiers    Chantier[]
  pointsLists  PointsList[]
  affectations AffectationProjet[]
  documents    Document[]
  /// Nom EXACT du dossier de ce client sur kDrive, s'il diffère de `nom` (accents,
  /// casse, suffixe juridique…). Null = on utilise `nom` (après normalisation).
  /// Sert à la résolution du chemin kDrive (voir src/lib/kdrive).
  kdriveDossier String?
}

/// État commercial d'une affaire (le financier — prix, coûts — reste dans WhySoft).
enum EtatAffaire {
  DEVIS
  COMMANDE
  EN_COURS
  LIVRE
  CLOTURE
}

/// État de synchronisation d'un document vers kDrive.
/// EN_ATTENTE : déposé (spool présent), pas encore poussé.
/// EN_COURS   : pris par un worker (claim atomique, anti double-push).
/// SYNC       : poussé sur kDrive (kdriveFileId présent, spool purgé).
/// ERREUR     : échec de push (voir syncError) — re-tenté avec backoff.
enum StatutSync {
  EN_ATTENTE
  EN_COURS
  SYNC
  ERREUR
}

/// Politique appliquée au push si un fichier de même nom existe dans le dossier
/// kDrive cible. VERSION = nouvelle version kDrive (défaut, non destructif) ;
/// RENAME = dépose à côté avec suffixe.
enum PolitiqueConflit {
  VERSION
  RENAME
}

/// Chantier = « Affaire » : pivot de la plateforme. Rattaché à un client, il
/// regroupe TOUT ce qui est produit pour une même affaire (numéro Why) à travers
/// tous les outils. Chaque outil pointe vers lui via `chantierId` ; la fiche
/// Affaire agrège les artefacts (voir src/lib/chantiers/providers.ts).
model Chantier {
  id        String      @id @default(cuid())
  nom       String
  reference String?
  /// Référence de l'affaire dans WhySoft (CRM) — clé naturelle de résolution.
  numeroWhy String?     @unique
  etat      EtatAffaire @default(DEVIS)
  /// Année de rangement kDrive (racine `chantier/{année}/…`). Null pour les
  /// affaires antérieures à la GED → on retombe sur l'année de `createdAt`
  /// (le chemin kDrive ne casse jamais). Éditable sur la fiche affaire.
  annee     Int?
  /// Cache de l'`id` du dossier d'affaire résolu sur kDrive (évite de re-naviguer
  /// l'arbo à chaque dépôt). Voir src/lib/kdrive/resolution.
  kdriveDirId String?
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  affectations AffectationProjet[]
  documents    Document[]

  @@index([clientId])
}

// ---- Outil « Liste de Points GTB » -----------------------------------------

/// Un document « liste de points » (partagé entre tous les utilisateurs).
/// Les lignes (points/sections) sont stockées en JSON : voir le type PointRow
/// dans src/tools/liste-points/model.ts.
model PointsList {
  id          String    @id @default(cuid())
  titre       String?
  clientNom   String    @default("")
  /// Lien vers le référentiel Client (null = client libre non rattaché).
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  /// Référence de l'affaire / du chantier dans WhySoft (CRM).
  numeroWhy   String?
  chantierNom String    @default("")
  date        DateTime?
  rows        Json      @default("[]")
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdById])
  @@index([clientId])
}

/// Catalogue de points partagé (nom → type d'E/S). Alimente le combobox de
/// point et s'enrichit quand un utilisateur ajoute un point personnalisé.
model PointCatalog {
  id        String   @id @default(cuid())
  nom       String   @unique
  type      String // AI | DI | AO | DO | COM
  /// Signal électrique par défaut (entrée : 0-10V/4-20mA/PT1000/D… ; sortie :
  /// 0-10V/4-20mA/PWM/D). Null = défaut selon le type. Permet une affectation
  /// directement correcte à l'insertion. Voir INPUT_SIGNALS/OUTPUT_SIGNALS.
  signal    String?
  createdAt DateTime @default(now())
}

/// Modèle de saisie : une section pré-remplie de points (Chaudière, CTA…),
/// insérable en un clic dans une liste. Éditable via /configuration/points.
/// `points` = JSON ordonné de { nom, type }. Seedé depuis TEMPLATES (catalog.ts).
model Modele {
  id        String   @id @default(cuid())
  nom       String   @unique
  ordre     Int      @default(0)
  points    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---- Outil « Affectation E/S depuis GFX » ----------------------------------

/// Base matériel éditable — modèle d'automate Distech (partagé entre tous).
/// Pilote le sélecteur d'automate, le moteur de recommandation et l'aperçu.
/// Seedé depuis src/tools/affectation-es/catalogue.ts (valeurs par défaut).
model AutomateModele {
  id            String   @id @default(cuid())
  reference     String   @unique
  ordre         Int      @default(0)
  actif         Boolean  @default(true)
  image         String   @default("")
  /// Alimentation intégrée au boîtier (sinon module d'alim externe).
  alimIntegree  Boolean  @default(false)
  alimLabel     String   @default("")
  /// E/S intégrées à l'automate (0 pour les bases modulaires type S1000E).
  entreeKind    String   @default("UI")
  entreeCount   Int      @default(0)
  sortieKind    String   @default("UO")
  sortieCount   Int      @default(0)
  /// Codes de bornes explicites pour les E/S mixtes (ex. PTU-207) — [] sinon.
  entreeCodes   Json     @default("[]")
  sortieCodes   Json     @default("[]")
  /// Accepte des modules d'extension.
  extensible    Boolean  @default(false)
  /// Types de modules compatibles (référence ModuleModele.type) — [] = aucun.
  modulesCompat Json     @default("[]")
  /// Nombre max de modules d'extension (0 = non extensible / non spécifié).
  maxModules    Int      @default(0)
  /// Capacité max en points d'E/S totale (0 = non spécifiée).
  maxPoints     Int      @default(0)
  /// Lien vers la fiche technique (PDF public, ex. /materiel/Documentations_Distech/...).
  docUrl        String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Base matériel éditable — modèle de module d'extension / communication.
model ModuleModele {
  id          String   @id @default(cuid())
  type        String   @unique
  ordre       Int      @default(0)
  actif       Boolean  @default(true)
  image       String   @default("")
  /// extension | communication | accessoire
  categorie   String   @default("extension")
  entreeKind  String   @default("UI")
  entreeCount Int      @default(0)
  sortieKind  String   @default("UO")
  sortieCount Int      @default(0)
  /// Lien vers la fiche technique (PDF public).
  docUrl      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Un projet d'affectation E/S (partagé). Le projet complet (infos chantier,
/// automate, réseaux, modules, points, suivi tests) est stocké en JSON —
/// voir le type Project dans src/tools/affectation-es/model.ts.
model AffectationProjet {
  id          String    @id @default(cuid())
  nom         String    @default("Nouveau projet")
  clientNom   String    @default("")
  /// Lien vers le référentiel Client (null = client libre non rattaché).
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  /// Référence de l'affaire / du chantier dans WhySoft (CRM).
  numeroWhy   String?
  /// Rattachement à l'Affaire (pivot). Null = non rattaché.
  chantierId  String?
  chantier    Chantier? @relation(fields: [chantierId], references: [id], onDelete: SetNull)
  data        Json      @default("{}")
  createdById String?
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdById])
  @@index([clientId])
  @@index([chantierId])
}

// ---- Outil « Documents » (GED) ---------------------------------------------

/// Un document téléversé, rattaché à une Affaire, et miroité sur kDrive.
/// Architecture : kDrive est le stockage MAÎTRE (le binaire n'est PAS conservé
/// durablement sur la VM). `spoolPath` est un tampon transitoire, effacé dès que
/// le push kDrive est confirmé (statutSync=SYNC). Une fois poussé, `kdriveFileId`
/// est l'ANCRE : renommer l'affaire ne déplace rien, l'id continue de pointer.
/// Voir src/lib/kdrive et la note mémoire ged-documents-kdrive.
model Document {
  id           String   @id @default(cuid())
  /// Nom de fichier d'origine (avec extension).
  nom          String
  /// Catégorie = sous-dossier kDrive (liste fermée, voir CATEGORIES dans model.ts).
  categorie    String
  mimeType     String   @default("application/octet-stream")
  /// Taille en octets (max applicatif : 500 Mo).
  taille       Int      @default(0)

  // --- rattachement (Affaire obligatoire) ---
  chantierId   String
  chantier     Chantier @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  /// Client dénormalisé (dérivé de l'affaire) pour la fiche client.
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  numeroWhy    String?

  // --- localisation ---
  /// Chemin du tampon transitoire sur la VM (présent tant que non SYNC, sinon null).
  spoolPath    String?
  /// Id du fichier sur kDrive une fois poussé (ancre de référence). Null avant push.
  kdriveFileId String?
  /// Chemin logique kDrive calculé au dépôt (info / reconstruction), ex.
  /// « chantier/2026/Client A/2026-0142 - Réf/Prog/fichier.gfx ».
  kdrivePath   String   @default("")

  // --- synchronisation ---
  statutSync       StatutSync       @default(EN_ATTENTE)
  politiqueConflit PolitiqueConflit @default(VERSION)
  /// Nombre de tentatives de push (pour le backoff / plafond du worker).
  tentatives       Int              @default(0)
  syncError        String?

  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([chantierId])
  @@index([clientId])
  @@index([statutSync])
}
