# Copier en .env.prod sur la VM. Ne jamais committer .env.prod.
#   docker compose --env-file .env.prod up -d --build

# Mot de passe de la base Postgres (interne au réseau Docker).
POSTGRES_PASSWORD=changer-ce-mot-de-passe

# Secret de session Auth.js — générer : openssl rand -base64 32
AUTH_SECRET=remplacer-par-un-secret-genere

# Nom de domaine interne servi par Caddy (doit résoudre vers la VM).
DOMAIN=outils.dumortier.local
# URL publique de l'app (doit correspondre au domaine ci-dessus).
AUTH_URL=https://outils.dumortier.local
