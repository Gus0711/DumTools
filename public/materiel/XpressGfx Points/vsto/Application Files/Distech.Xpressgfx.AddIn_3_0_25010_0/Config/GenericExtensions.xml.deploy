  <GenericExtension id="9" name="{ECSmartFullName:EC-Smart-Full}">
    <Registers>
      <Register name="EffectSetpointOffset"  	registerType="3" dataType="Float" address="1" endianness="1" readWrite="1"	direction="1" default="0"/>
      <Register name="ConfigInput" registerType="3" dataType="Bit" address="3" endianness="1" readWrite="1"	direction="1" default="0">
        <BitFields>
          <BitField name="SetpointMode"	 initialVisible="false" offset="0" length="1"/>
          <BitField name="SetpointSteps" initialVisible="false" offset="1" length="7"/>
          <BitField name="SetpointRange" initialVisible="false" offset="8" length="4"/>
        </BitFields>
      </Register>
      <Register name="InputStatus" registerType="3" dataType="Bit" address="0" endianness="1" readWrite="1" direction="1">
        <!--default value 0b0000111 00111111(1855) => Occ = 7(means not connected input) , FanSpeed = 7(means not connected input), Intensity = 14 -->
