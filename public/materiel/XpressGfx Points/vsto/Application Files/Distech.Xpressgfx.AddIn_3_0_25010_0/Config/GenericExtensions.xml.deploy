      <!--<Register name="Elevation" siUnit="31" initialVisible="false" registerType="3" dataType="Float" address="5" endianness="1" readWrite="1"  direction="1" useDefault="true" default="NaN"/>-->
      <Register name="SpaceTemp" siUnit="62"   registerType="3"  dataType="Float" address="36"  endianness="1" readWrite="0"	direction="2" default="NaN"/>
