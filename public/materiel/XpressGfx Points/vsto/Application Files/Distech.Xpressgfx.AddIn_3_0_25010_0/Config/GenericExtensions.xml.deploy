        <BitFields>
          <BitField name="SetpointOffsetUpdate" enumKeyBacnet="boolean" enumKeyShortStack="boolean"  	offset="0" length="1" />
          <!--<BitField name="OccupancyUpdate" enumKeyBacnet="boolean" enumKeyShortStack="boolean" 	offset="1" length="1" />
          <BitField name="FanSpeedUpdate" enumKeyBacnet="boolean" enumKeyShortStack="boolean"  	offset="2" length="1" />-->
          <BitField name="DigitalInputUpdate1" enumKeyShortStack="boolean" enumKeyBacnet="boolean"  initialVisible="false" offset="8" length="1" />
          <BitField name="DigitalInputUpdate2" enumKeyShortStack="boolean" enumKeyBacnet="boolean"  initialVisible="false" offset="9" length="1" />
