  <GenericExtension id="1" name="{ECSmartComfortTSName:EC-Smart-Comfort-S}">
    <Registers>
      <Register name="EffectSetpointOffset"  	 registerType="3" dataType="Float" address="1" endianness="1" readWrite="1"	direction="1" useDefault="true" default="NaN"/>
