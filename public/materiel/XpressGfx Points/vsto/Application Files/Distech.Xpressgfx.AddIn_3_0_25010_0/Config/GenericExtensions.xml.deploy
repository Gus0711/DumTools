      <Register name="SetpointOffset" conversion="false"  siUnit="121"     registerType="3"  dataType="Float" address="34"  endianness="1" readWrite="0"	direction="2" default="NaN"/>
      <Register name="OutputStatus" registerType="3" dataType="Bit" address="32" endianness="1" readWrite="0"	direction="2" default="1">
        <BitFields>
          <!--<BitField name="Occupancy" enumKeyBacnet="Bacnet.Standard.Occupancy" enumKeyShortStack="SNVT_occupancy" isEnum="true" offset="0" length="3" />-->
