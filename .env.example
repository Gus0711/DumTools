# Copier en .env et adapter. Ne jamais committer .env.
# --- Base de données ---------------------------------------------------------
DATABASE_URL="postgresql://dumtools:dumtools@localhost:5433/dumtools?schema=public"

# --- Auth.js -----------------------------------------------------------------
# Générer un secret : openssl rand -base64 32
AUTH_SECRET="remplacer-par-un-secret-genere"
# En dev : laisser AUTH_URL vide (trustHost:true suit le host réel, localhost ou
# IP LAN). Le figer casse la redirection en accès par IP.
# En prod : le fixer sur le domaine public (ex. https://outils.dumortier.local).
# AUTH_URL="https://outils.dumortier.local"

# --- Outil « Documents » (GED) / kDrive --------------------------------------
# Sans ces variables, l'outil fonctionne quand même : les dépôts restent « en
# attente » sur le spool jusqu'à ce que kDrive soit configuré.
# Répertoire tampon (transitoire) des fichiers déposés avant push kDrive.
DOCUMENTS_SPOOL_DIR=".spool"
# Secret partagé protégeant la route de synchro appelée par le cron.
DOCUMENTS_DRAIN_SECRET="remplacer-par-un-secret-genere"
# kDrive Infomaniak (un seul compte de service) — voir le spike src/lib/kdrive.
KDRIVE_TOKEN=""
KDRIVE_DRIVE_ID=""
# id du dossier racine « chantier/ » sous lequel vit {année}/{client}/{affaire}.
KDRIVE_ROOT_DIR_ID=""
# Version d'API (à confirmer au spike : 2 ou 3).
# KDRIVE_API_VERSION="3"
